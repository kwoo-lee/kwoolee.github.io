---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_AUTHOR, CONTACT } from '../consts';
---

<BaseLayout title="About" description={`About ${SITE_AUTHOR}`}>
  <section class="post-header">
    <h1>About</h1>
    <p style="color: var(--color-text-muted); font-size: 1.1rem; margin: 0;">
      A little about who's writing here.
    </p>
  </section>

  <div class="post-body">
    <p>
      I'm {SITE_AUTHOR}. I build software for a living and write about it here.
      This site is a place to keep notes I'd otherwise lose to scratch files —
      things I learned, problems I worked through, projects I shipped.
    </p>

    <h2>Get in touch</h2>
    <p>
      The fastest way to reach me is <a href={`mailto:${CONTACT.email}`}>email</a>.
      You can also find me on <a href={CONTACT.github}>GitHub</a> or
      <a href={CONTACT.linkedin}>LinkedIn</a>.
    </p>
  </div>
</BaseLayout>
